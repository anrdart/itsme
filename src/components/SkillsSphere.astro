---
// src/components/SkillsSphere.astro
import { SKILLS_DATA } from '../data/skills.js';
---
<div id="skills-sphere-container" class="skills-sphere-container" role="img" aria-label="Interactive 3D skills visualization">
  <!-- Shimmer loader while the WebGL scene + textures boot -->
  <div id="sphere-loader" class="sphere-loader" aria-hidden="true" hidden>
    <span class="skeleton sphere-skeleton"></span>
    <span class="sphere-loader-label">Loading stack…</span>
  </div>
  <canvas id="skills-sphere-canvas" aria-hidden="true"></canvas>

  <!-- Fallback grid if WebGL not available -->
  <ul class="skills-fallback" id="skills-fallback" role="list" aria-label="Technical skills" style="display:none">
    {SKILLS_DATA.map(skill => (
      <li class="skill-item card">
        <img
          src={skill.icon}
          alt={skill.name}
          width="52"
          height="52"
          loading="lazy"
        />
        <span class="skill-name">{skill.name}</span>
      </li>
    ))}
  </ul>
</div>

<style>
.skills-sphere-container {
  position: relative;
  width: 100%;
  height: 70vh;
  min-height: 400px;
  content-visibility: auto;
  contain-intrinsic-size: 70vh;
}

#skills-sphere-canvas {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0;
  transition: opacity 700ms var(--ease);
}
.skills-sphere-container.is-ready #skills-sphere-canvas { opacity: 1; }

/* Shimmer loader */
.sphere-loader {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  z-index: 2;
  transition: opacity 500ms var(--ease);
}
.skills-sphere-container.is-ready .sphere-loader {
  opacity: 0;
  pointer-events: none;
}
.sphere-skeleton {
  width: min(260px, 60vw);
  height: min(260px, 60vw);
  border-radius: 50%;
}
.sphere-loader-label {
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-mut);
}

.skills-fallback {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 16px;
  list-style: none;
  padding: 0;
}

.skill-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 12px;
  text-align: center;
}

.skill-name {
  font-size: 12px;
  color: var(--text-sec);
  font-weight: 500;
}
</style>

<script>
  import { initSkillsSphere } from '../scripts/skills-sphere.js';

  let sphere: ReturnType<typeof initSkillsSphere> = null;

  document.addEventListener('astro:before-swap', () => {
    if (sphere) {
      sphere.dispose();
      sphere = null;
    }
  });

  function boot() {
    const container = document.getElementById('skills-sphere-container');
    if (!container || sphere) return;

    const loader = document.getElementById('sphere-loader');
    if (loader) loader.hidden = false;

    sphere = initSkillsSphere('skills-sphere-container', 'dark');

    // Reveal once textures have had a moment to load; rAF keeps it smooth.
    requestAnimationFrame(() => {
      setTimeout(() => container.classList.add('is-ready'), 220);
    });
  }

  function init() {
    const container = document.getElementById('skills-sphere-container');
    if (!container) return;

    // No WebGL → skip the 3D entirely, show the grid fallback.
    const probe = document.createElement('canvas');
    const gl = probe.getContext('webgl') || probe.getContext('experimental-webgl');
    if (!gl) {
      document.getElementById('skills-sphere-canvas')?.remove();
      document.getElementById('sphere-loader')?.remove();
      const fallback = document.getElementById('skills-fallback');
      if (fallback) fallback.style.display = 'grid';
      return;
    }

    // Boot the 3D scene automatically on load.
    boot();
  }

  document.addEventListener('astro:page-load', init);
</script>
