---
// src/components/Preloader.astro
// Bold kinetic intro - original work, studio-style energy (RESN-ish), not a copy.
// A giant full-bleed counter sweeps 0->100 behind an accent progress sheet,
// then the overlay lifts with a clip-path wipe while the hero rises in.
// Shows ONLY on the genuine first load of a session (gated by html.pl-first).
---
<!-- Runs before the rest of <body> paints: decide if the intro should show.
     Gating here (not the deferred module) avoids a flash of the overlay on
     SPA navigations, where this markup re-renders but must stay hidden. -->
<script is:inline>
  (function () {
    try {
      var seen = sessionStorage.getItem('pl-seen') === '1';
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!seen && !reduce) {
        document.documentElement.classList.add('pl-first', 'pl-intro');
      }
    } catch (e) { /* sessionStorage blocked → skip the intro */ }
  })();
</script>

<div id="preloader" class="preloader" aria-hidden="true" data-state="idle">
  <!-- top + bottom panels lift apart on reveal -->
  <span class="pl-panel pl-panel-top"></span>
  <span class="pl-panel pl-panel-bottom"></span>

  <div class="pl-stage">
    <span class="pl-kicker">Portfolio of</span>

    <!-- kinetic word ticker: words rise through a mask, finishing on the name -->
    <div class="pl-words" id="pl-words" aria-hidden="true">
      <span class="pl-word" data-word="0">CRAFT</span>
      <span class="pl-word" data-word="1">BUILD</span>
      <span class="pl-word" data-word="2">SHIP</span>
      <span class="pl-word pl-word-brand" data-word="3">єкαℓℓιρтuѕ</span>
    </div>

    <!-- accent line that grows across the load -->
    <span class="pl-rule"><span class="pl-rule-fill" id="pl-fill"></span></span>

    <span class="pl-tag">Software Engineer</span>
  </div>
</div>

<style>
  /* Hidden by default - only the first load of a session opts in. */
  .preloader { display: none; }
  :global(html.pl-first) .preloader {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 10000;
    overflow: hidden;
  }
  .preloader[data-state="done"] { display: none !important; }

  /* lock scroll while the intro plays */
  :global(html.pl-lock),
  :global(html.pl-lock body) { overflow: hidden; height: 100%; }

  /* ── Splitting panels (the curtain) ── */
  .pl-panel {
    position: absolute;
    left: 0;
    width: 100%;
    height: 50.5%;
    background: var(--bg);
    z-index: 1;
    will-change: transform;
  }
  .pl-panel-top { top: 0; }
  .pl-panel-bottom { bottom: 0; }

  /* Reveal: panels slide apart, weighty easing */
  .preloader[data-state="reveal"] .pl-panel-top {
    transform: translateY(-100%);
    transition: transform 1100ms cubic-bezier(0.85, 0, 0.15, 1) 180ms;
  }
  .preloader[data-state="reveal"] .pl-panel-bottom {
    transform: translateY(100%);
    transition: transform 1100ms cubic-bezier(0.85, 0, 0.15, 1) 180ms;
  }

  /* ── Stage (counter cluster) ── */
  .pl-stage {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    transition: opacity 460ms var(--ease), transform 700ms var(--ease);
  }
  .preloader[data-state="reveal"] .pl-stage {
    opacity: 0;
    transform: scale(0.96);
    transition-duration: 380ms;
  }

  .pl-kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--text-mut);
    opacity: 0;
    transform: translateY(10px);
    animation: pl-in 700ms var(--ease) 80ms forwards;
  }

  /* ── Kinetic word ticker (opacity + slide cross-fade) ── */
  .pl-words {
    position: relative;
    width: min(90vw, 900px);
    height: 1.15em;
    font-family: var(--font-body);
    font-size: clamp(2.6rem, 9vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }
  .pl-word {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    color: var(--text);
    opacity: 0;
    transform: translateY(26px);
    will-change: opacity, transform;
  }
  /* current word visible + centered; outgoing word fades up and out */
  .pl-word.is-in  { opacity: 1; transform: translateY(0); }
  .pl-word.is-out { opacity: 0; transform: translateY(-26px); }
  .pl-words.animate .pl-word {
    transition: opacity 420ms var(--ease), transform 520ms cubic-bezier(0.76, 0, 0.24, 1);
  }
  .pl-word-brand {
    font-family: serif;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--accent);
  }

  /* Progress rule */
  .pl-rule {
    position: relative;
    width: min(360px, 70vw);
    height: 2px;
    background: var(--line);
    overflow: hidden;
  }
  .pl-rule-fill {
    position: absolute;
    inset: 0 100% 0 0;          /* right inset animates the fill */
    background: var(--accent);
    transition: right 140ms linear;
  }

  .pl-tag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-mut);
    opacity: 0;
    transform: translateY(12px);
    animation: pl-in 800ms var(--ease) 260ms forwards;
  }

  @keyframes pl-in {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const SESSION_KEY = 'pl-seen';

  function runPreloader() {
    const html = document.documentElement;
    const pl = document.getElementById('preloader');
    if (!pl || !html.classList.contains('pl-first')) return;

    sessionStorage.setItem(SESSION_KEY, '1');

    const wordsWrap = document.getElementById('pl-words');
    const fillEl = document.getElementById('pl-fill');
    const words = wordsWrap ? Array.from(wordsWrap.querySelectorAll('.pl-word')) : [];

    html.classList.add('pl-lock');
    pl.dataset.state = 'counting';

    const STEP = 760;                         // ms per word (480ms slide + ~280ms hold)
    const total = words.length * STEP;        // full ticker duration
    const timers: ReturnType<typeof setTimeout>[] = [];

    // First word in immediately (no transition flash), then enable transitions.
    if (words[0]) words[0].classList.add('is-in');
    requestAnimationFrame(() => wordsWrap?.classList.add('animate'));

    // Grow the accent rule across the whole sequence.
    if (fillEl) {
      fillEl.style.transition = `right ${total}ms cubic-bezier(0.4,0,0.2,1)`;
      requestAnimationFrame(() => { fillEl.style.right = '0%'; });
    }

    // Sequence the words: each step lifts the current out and brings the next in.
    for (let i = 1; i < words.length; i++) {
      timers.push(setTimeout(() => {
        words[i - 1].classList.remove('is-in');
        words[i - 1].classList.add('is-out');
        words[i].classList.add('is-in');
      }, i * STEP));
    }

    // After the last word (the brand) has held, reveal the site.
    timers.push(setTimeout(reveal, total + 360));

    function reveal() {
      pl.dataset.state = 'reveal';     // panels split + stage fades
      html.classList.remove('pl-lock');
      // Hand off to the hero opening as the panels lift.
      html.classList.remove('pl-intro');
      html.classList.add('pl-opening');
      // panels: 180ms delay + 1100ms travel ≈ 1280ms
      timers.push(setTimeout(() => {
        pl.dataset.state = 'done';
        html.classList.remove('pl-first', 'pl-opening');
      }, 1500));
    }
  }

  document.addEventListener('astro:page-load', runPreloader, { once: true });
</script>
